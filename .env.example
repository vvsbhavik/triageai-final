# ====================================================================
# TRIAGEAI REQUIRED ENVIRONMENT VARIABLES BLUEPRINT
# ====================================================================

# 1. AI API KEYS
# GEMINI_API_KEY: Secondary AI backup model. Automatically injected by AI Studio.
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# OPENAI_API_KEY: Primary AI engine for structured clinical triage analysis.
OPENAI_API_KEY="YOUR_OPENAI_API_KEY"


# 2. SUPABASE CONNECTIVITY
# SUPABASE_URL: The endpoint URL of your Supabase project (e.g. https://xxxxxx.supabase.co)
SUPABASE_URL="YOUR_SUPABASE_URL"

# SUPABASE_ANON_KEY: The public anonymous API key of your Supabase project.
SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"


# 3. LOCATION & MAPPING API
# GOOGLE_MAPS_API_KEY: Exclusively used on the backend to power Google Places API (New) nearby hospital search.
GOOGLE_MAPS_API_KEY="YOUR_GOOGLE_MAPS_API_KEY"


# 4. APPLET SPECIFICATIONS
# APP_URL: Injected automatically by the hosting platform (e.g., Cloud Run or Vercel).
APP_URL="MY_APP_URL"
